<?xml version="1.0" encoding="UTF-8"?>
<test-data
    xmlns="http://pmd.sourceforge.net/rule-tests"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/rule-tests http://pmd.sourceforge.net/rule-tests_1_0_0.xsd">
    <test-code>
        <description>class Fo$o</description>
        <expected-problems>1</expected-problems>
        <code><![CDATA[
public class F$oo {}
        ]]></code>
    </test-code>

    <test-code>
        <description>field fo$o</description>
        <expected-problems>1</expected-problems>
        <code><![CDATA[
public class Foo {
    int fo$o;
}
        ]]></code>
    </test-code>

    <test-code>
        <description>method foo$oo</description>
        <expected-problems>1</expected-problems>
        <code><![CDATA[
public class Foo {
    void fo$o() {}
}
        ]]></code>
    </test-code>

    <test-code>
        <description>interface fo$oo</description>
        <expected-problems>1</expected-problems>
        <code><![CDATA[
public interface Foo$oo {}
        ]]></code>
    </test-code>

    <test-code>
        <description>ok</description>
        <expected-problems>0</expected-problems>
        <code><![CDATA[
public class Foo {
    void foo() {}
    int buz;
}
public interface Baz {}
        ]]></code>
    </test-code>


    <test-code>
        <description>Verify location of violation</description>
        <expected-problems>7</expected-problems>
        <expected-linenumbers>2-2,5-5,9-9,13-13,17-17,21-21,25-25</expected-linenumbers>
        <code><![CDATA[
public class
F$oo // <--violation: line 2
{
    int
    fo$o // <--violation: line 5
    ;

    void
    fo$o // <--violation: line 9
    () {}

    public interface
    Foo$oo // <--violation: line 13
    {}

    public enum
    Foo$enum // <--violation: line 17
    { A }

    public record
    Foo$record // <--violation: line 21
    (int a) {}

    public record MyRecord (int
        a$foo // <--violation: line 25
    ) {}
}
        ]]></code>
    </test-code>
</test-data>
